# Copier vers server/.env et renseigner les valeurs (NE JAMAIS mettre de vrais secrets ici).

# PostgreSQL (Neon) — connexion runtime : utiliser l'endpoint POOLER (-pooler)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Connexion DIRECTE (sans -pooler) — utilisée par Prisma pour les migrations
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# Secret JWT — chaîne aléatoire >= 32 caractères (ex: openssl rand -base64 48)
JWT_SECRET="change-me-please-with-a-long-random-secret"

# Réseau
PORT=3000
CLIENT_ORIGIN="http://localhost:5173"
NODE_ENV="development"

# Compte admin unique (authentification simple, pas de gestion d'utilisateurs)
ADMIN_EMAIL="admin@gca.local"
ADMIN_PASSWORD="admin1234"
